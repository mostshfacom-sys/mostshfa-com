generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:../../prisma/dev.db"
}

model User {
  id            Int                @id @default(autoincrement())
  email         String             @unique
  password      String
  name          String?
  phone         String?
  image         String?
  role          String             @default("user")
  isActive      Boolean            @default(true) @map("is_active")
  createdAt     DateTime           @default(now()) @map("created_at")
  updatedAt     DateTime           @updatedAt @map("updated_at")
  medicines     MedicineReminder[]
  weightRecords WeightRecord[]
  pressureLogs  PressureLog[]
  foodEntries   FoodEntry[]
  sleepRecords  SleepRecord[]
  fcmTokens     FCMToken[]

  @@map("users")
}

model Governorate {
  id         Int        @id @default(autoincrement())
  nameAr     String     @unique @map("name_ar")
  nameEn     String?    @map("name_en")
  cities     City[]
  hospitals  Hospital[]
  clinics    Clinic[]
  labs       Lab[]
  pharmacies Pharmacy[]
  createdAt  DateTime   @default(now()) @map("created_at")
  updatedAt  DateTime   @updatedAt @map("updated_at")

  @@map("governorates")
}

model City {
  id            Int         @id @default(autoincrement())
  governorateId Int         @map("governorate_id")
  governorate   Governorate @relation(fields: [governorateId], references: [id])
  nameAr        String      @map("name_ar")
  nameEn        String?     @map("name_en")
  hospitals     Hospital[]
  clinics       Clinic[]
  labs          Lab[]
  pharmacies    Pharmacy[]
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  @@unique([governorateId, nameAr])
  @@index([governorateId])
  @@map("cities")
}

model HospitalType {
  id          Int        @id @default(autoincrement())
  nameAr      String     @map("name_ar")
  nameEn      String?    @map("name_en")
  slug        String     @unique
  icon        String?
  color       String?
  description String?
  isActive    Boolean    @default(true) @map("is_active")
  order       Int        @default(0)
  hospitals   Hospital[]
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  @@map("hospital_types")
}

model Specialty {
  id        Int        @id @default(autoincrement())
  nameAr    String     @map("name_ar")
  nameEn    String?    @map("name_en")
  slug      String     @unique
  icon      String?
  hospitals Hospital[]
  clinics   Clinic[]
  staff     Staff[]
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")

  @@map("specialties")
}

model Hospital {
  id            Int           @id @default(autoincrement())
  nameAr        String        @map("name_ar")
  nameEn        String?       @map("name_en")
  slug          String        @unique
  typeId        Int?          @map("type_id")
  type          HospitalType? @relation(fields: [typeId], references: [id])
  governorateId Int?          @map("governorate_id")
  governorate   Governorate?  @relation(fields: [governorateId], references: [id])
  cityId        Int?          @map("city_id")
  city          City?         @relation(fields: [cityId], references: [id])
  address       String?
  phone         String?
  whatsapp      String?
  website       String?
  facebook      String?
  logo          String?
  description   String?
  hasEmergency  Boolean       @default(false) @map("has_emergency")
  isFeatured    Boolean       @default(false) @map("is_featured")
  ratingAvg     Float         @default(0) @map("rating_avg")
  ratingCount   Int           @default(0) @map("rating_count")
  lat           Float?
  lng           Float?
  category      String?

  // الحقول الجديدة للنظام المحسن
  metadata             String  @default("{}")
  workingHours         String  @default("{}") @map("working_hours")
  services             String  @default("[]")
  insuranceAccepted    String  @default("[]") @map("insurance_accepted")
  emergencyServices    String  @default("{}") @map("emergency_services")
  parkingAvailable     Boolean @default(false) @map("parking_available")
  wheelchairAccessible Boolean @default(false) @map("wheelchair_accessible")
  hasAmbulance         Boolean @default(false) @map("has_ambulance")
  beds                 Int     @default(0)
  operator             String?
  email                String?
  languagesSpoken      String  @default("[]") @map("languages_spoken")
  isVerified           Boolean @default(false) @map("is_verified")

  reviews          Review[]
  specialties      Specialty[]
  hospitalStaff    HospitalStaff[]
  workingHoursList WorkingHour[]
  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime        @updatedAt @map("updated_at")

  @@index([governorateId])
  @@index([cityId])
  @@index([typeId])
  @@index([isFeatured, ratingAvg])
  @@index([hasEmergency])
  @@map("hospitals")
}

model Review {
  id         Int      @id @default(autoincrement())
  hospitalId Int      @map("hospital_id")
  hospital   Hospital @relation(fields: [hospitalId], references: [id], onDelete: Cascade)
  author     String
  rating     Int
  text       String?
  time       String?
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@index([hospitalId])
  @@map("reviews")
}

model WorkingHour {
  id         Int      @id @default(autoincrement())
  hospitalId Int      @map("hospital_id")
  hospital   Hospital @relation(fields: [hospitalId], references: [id], onDelete: Cascade)
  day        String // Sunday, Monday, etc.
  openTime   String?  @map("open_time")
  closeTime  String?  @map("close_time")
  isClosed   Boolean  @default(false) @map("is_closed")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@unique([hospitalId, day])
  @@map("working_hours_list")
}

model Clinic {
  id                 Int           @id @default(autoincrement())
  nameAr             String        @map("name_ar")
  nameEn             String?       @map("name_en")
  slug               String        @unique
  descriptionAr      String?       @map("description_ar")
  phone              String?
  whatsapp           String?
  email              String?
  website            String?
  facebook           String?
  instagram          String?
  twitter            String?
  linkedin           String?
  videoUrl           String?       @map("video_url")
  logo               String?
  image              String?
  gallery            String        @default("[]") // Array of image URLs
  workingHours       String        @default("{}") @map("working_hours")
  services           String        @default("[]")
  insuranceCompanies String        @default("[]") @map("insurance_companies")
  amenities          String        @default("[]") // WiFi, Parking, etc.
  metadata           String        @default("{}")
  governorateId      Int?          @map("governorate_id")
  governorate        Governorate?  @relation(fields: [governorateId], references: [id])
  cityId             Int?          @map("city_id")
  city               City?         @relation(fields: [cityId], references: [id])
  addressAr          String?       @map("address_ar")
  lat                Float?
  lng                Float?
  hours              String?
  emergencyPhone     String?       @map("emergency_phone")
  consultationFee    Float?        @map("consultation_fee")
  waitingTime        String?       @map("waiting_time")
  parkingAvailable   Boolean       @default(false) @map("parking_available")
  wifiAvailable      Boolean       @default(false) @map("wifi_available")
  isOpen             Boolean       @default(true) @map("is_open")
  isFeatured         Boolean       @default(false) @map("is_featured")
  ratingAvg          Float         @default(0) @map("rating_avg")
  ratingCount        Int           @default(0) @map("rating_count")
  status             String        @default("published")
  specialties        Specialty[]
  clinicStaff        ClinicStaff[]
  createdAt          DateTime      @default(now()) @map("created_at")
  updatedAt          DateTime      @updatedAt @map("updated_at")

  @@index([governorateId])
  @@index([cityId])
  @@map("clinics")
}

model Lab {
  id              Int          @id @default(autoincrement())
  nameAr          String       @map("name_ar")
  nameEn          String?      @map("name_en")
  slug            String       @unique
  descriptionAr   String?      @map("description_ar")
  phone           String?
  whatsapp        String?
  email           String?
  website         String?
  facebook        String?
  logo            String?
  governorateId   Int?         @map("governorate_id")
  governorate     Governorate? @relation(fields: [governorateId], references: [id])
  cityId          Int?         @map("city_id")
  city            City?        @relation(fields: [cityId], references: [id])
  addressAr       String?      @map("address_ar")
  lat             Float?
  lng             Float?
  hasHomeSampling Boolean      @default(false) @map("has_home_sampling")
  hours           String?
  isOpen          Boolean      @default(true) @map("is_open")
  isFeatured      Boolean      @default(false) @map("is_featured")
  ratingAvg       Float        @default(0) @map("rating_avg")
  ratingCount     Int          @default(0) @map("rating_count")
  status          String       @default("published")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  @@index([governorateId])
  @@index([cityId])
  @@map("labs")
}

model Pharmacy {
  id                 Int          @id @default(autoincrement())
  nameAr             String       @map("name_ar")
  nameEn             String?      @map("name_en")
  slug               String       @unique
  descriptionAr      String?      @map("description_ar")
  phone              String?
  hotline            String?
  whatsapp           String?
  email              String?
  website            String?
  facebook           String?
  logo               String?
  image              String?
  governorateId      Int?         @map("governorate_id")
  governorate        Governorate? @relation(fields: [governorateId], references: [id])
  cityId             Int?         @map("city_id")
  city               City?        @relation(fields: [cityId], references: [id])
  addressAr          String?      @map("address_ar")
  lat                Float?
  lng                Float?
  hasDeliveryService Boolean      @default(false) @map("has_delivery_service")
  hasNursingService  Boolean      @default(false) @map("has_nursing_service")
  hours              String?
  workingHours       String       @default("{}") @map("working_hours")
  services           String       @default("[]")
  metadata           String       @default("{}")
  isOpen             Boolean      @default(true) @map("is_open")
  isFeatured         Boolean      @default(false) @map("is_featured")
  is24h              Boolean      @default(false) @map("is_24h")
  ratingAvg          Float        @default(0) @map("rating_avg")
  ratingCount        Int          @default(0) @map("rating_count")
  status             String       @default("published")
  createdAt          DateTime     @default(now()) @map("created_at")
  updatedAt          DateTime     @updatedAt @map("updated_at")

  @@index([governorateId])
  @@index([cityId])
  @@map("pharmacies")
}

model DrugCategory {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  legacyId  Int?     @map("legacy_id")
  drugs     Drug[]
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("drug_categories")
}

model Drug {
  id                Int           @id @default(autoincrement())
  categoryId        Int?          @map("category_id")
  category          DrugCategory? @relation(fields: [categoryId], references: [id])
  legacyId          Int?          @map("legacy_id")
  nameAr            String        @map("name_ar")
  nameEn            String?       @map("name_en")
  slug              String        @unique
  image             String?
  usage             String?
  contraindications String?
  dosage            String?
  activeIngredient  String?       @map("active_ingredient")
  disclaimer        String?
  priceText         String?       @map("price_text")
  oldPrice          String?       @map("old_price")
  unitPrice         String?       @map("unit_price")
  barcode           String?
  units             String?
  company           String?
  lastUpdatedPrice  String?       @map("last_updated_price")
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")

  @@index([categoryId])
  @@map("drugs")
}

model ArticleCategory {
  id     Int     @id @default(autoincrement())
  nameAr String  @map("name_ar")
  nameEn String? @map("name_en")
  slug   String  @unique
  icon   String?
  color  String?

  // الحقول الجديدة للهيكل الهرمي
  parentId Int?              @map("parent_id")
  parent   ArticleCategory?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children ArticleCategory[] @relation("CategoryHierarchy")
  order    Int               @default(0)
  isActive Boolean           @default(true) @map("is_active")

  articles   Article[]
  healthTips HealthTip[]
  createdAt  DateTime    @default(now()) @map("created_at")
  updatedAt  DateTime    @updatedAt @map("updated_at")

  @@index([parentId])
  @@index([isActive, order])
  @@map("article_categories")
}

model Article {
  id          Int              @id @default(autoincrement())
  categoryId  Int?             @map("category_id")
  category    ArticleCategory? @relation(fields: [categoryId], references: [id])
  title       String
  slug        String           @unique
  excerpt     String?
  content     String?
  image       String?
  author      String?
  tags        String?
  views       Int              @default(0)
  isFeatured  Boolean          @default(false) @map("is_featured")
  isPublished Boolean          @default(true) @map("is_published")
  publishedAt DateTime?        @map("published_at")

  // الحقول الجديدة للنظام المحسن
  readingTime        Int     @default(0) @map("reading_time")
  difficultyLevel    String  @default("beginner") @map("difficulty_level")
  medicalSpecialties String  @default("[]") @map("medical_specialties")
  targetAudience     String  @default("[]") @map("target_audience")
  factChecked        Boolean @default(false) @map("fact_checked")
  medicalDisclaimer  Boolean @default(true) @map("medical_disclaimer")

  // العلاقات الجديدة
  tagRelations ArticleTagRelation[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([categoryId])
  @@index([isPublished])
  @@index([isFeatured])
  @@map("articles")
}

model Staff {
  id              Int             @id @default(autoincrement())
  nameAr          String          @map("name_ar")
  nameEn          String?         @map("name_en")
  slug            String          @unique
  title           String?
  specialtyId     Int?            @map("specialty_id")
  specialty       Specialty?      @relation(fields: [specialtyId], references: [id])
  bio             String?
  image           String?
  phone           String?
  email           String?
  experience      Int?
  education       String?
  certifications  String?
  qualifications  String?
  languages       String?
  consultationFee Float?          @map("consultation_fee")
  availableDays   String?         @map("available_days")
  isFeatured      Boolean         @default(false) @map("is_featured")
  isActive        Boolean         @default(true) @map("is_active")
  ratingAvg       Float           @default(0) @map("rating_avg")
  ratingCount     Int             @default(0) @map("rating_count")
  hospitalStaff   HospitalStaff[]
  clinicStaff     ClinicStaff[]
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  @@index([specialtyId])
  @@map("staff")
}

model HospitalStaff {
  id         Int      @id @default(autoincrement())
  hospitalId Int      @map("hospital_id")
  hospital   Hospital @relation(fields: [hospitalId], references: [id], onDelete: Cascade)
  staffId    Int      @map("staff_id")
  staff      Staff    @relation(fields: [staffId], references: [id])
  position   String?
  department String?
  isHead     Boolean  @default(false) @map("is_head")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([hospitalId])
  @@index([staffId])
  @@map("hospital_staff")
}

model ClinicStaff {
  id        Int      @id @default(autoincrement())
  clinicId  Int      @map("clinic_id")
  clinic    Clinic   @relation(fields: [clinicId], references: [id])
  staffId   Int      @map("staff_id")
  staff     Staff    @relation(fields: [staffId], references: [id])
  isOwner   Boolean  @default(false) @map("is_owner")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([clinicId])
  @@index([staffId])
  @@map("clinic_staff")
}

model ArticleTag {
  id         Int                  @id @default(autoincrement())
  nameAr     String               @unique @map("name_ar")
  nameEn     String?              @map("name_en")
  slug       String               @unique
  color      String               @default("#10B981")
  usageCount Int                  @default(0) @map("usage_count")
  articles   ArticleTagRelation[]
  createdAt  DateTime             @default(now()) @map("created_at")

  @@map("article_tags")
}

model ArticleTagRelation {
  articleId Int        @map("article_id")
  tagId     Int        @map("tag_id")
  article   Article    @relation(fields: [articleId], references: [id], onDelete: Cascade)
  tag       ArticleTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([articleId, tagId])
  @@map("article_tag_relations")
}

model MedicalTool {
  id                 String   @id @default(uuid())
  nameAr             String   @map("name_ar")
  nameEn             String?  @map("name_en")
  slug               String   @unique
  descriptionAr      String   @map("description_ar")
  descriptionEn      String?  @map("description_en")
  toolType           String   @map("tool_type")
  componentName      String   @map("component_name")
  config             String   @default("{}")
  medicalSpecialties String   @default("[]") @map("medical_specialties")
  targetConditions   String   @default("[]") @map("target_conditions")
  accuracyLevel      String   @map("accuracy_level")
  icon               String?
  featuredImage      String?  @map("featured_image")
  instructionsAr     String?  @map("instructions_ar")
  instructionsEn     String?  @map("instructions_en")
  usageCount         Int      @default(0) @map("usage_count")
  averageRating      Float    @default(0.00) @map("average_rating")
  ratingCount        Int      @default(0) @map("rating_count")
  isActive           Boolean  @default(true) @map("is_active")
  isFeatured         Boolean  @default(false) @map("is_featured")
  metaTitleAr        String?  @map("meta_title_ar")
  metaTitleEn        String?  @map("meta_title_en")
  metaDescriptionAr  String?  @map("meta_description_ar")
  metaDescriptionEn  String?  @map("meta_description_en")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")
  ratings            Rating[]

  @@index([toolType])
  @@index([isActive, isFeatured])
  @@index([usageCount])
  @@map("medical_tools")
}

model MedicineReminder {
  id           Int            @id @default(autoincrement())
  userId       Int            @map("user_id")
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  name         String
  dosage       String
  frequency    String
  times        String         @default("[]")
  startDate    DateTime       @map("start_date")
  durationDays Int            @map("duration_days")
  notes        String?
  isActive     Boolean        @default(true) @map("is_active")
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")
  doses        MedicineDose[]

  @@index([userId, isActive])
  @@index([startDate])
  @@map("medicine_reminders")
}

model MedicineDose {
  id            Int              @id @default(autoincrement())
  medicineId    Int              @map("medicine_id")
  medicine      MedicineReminder @relation(fields: [medicineId], references: [id], onDelete: Cascade)
  scheduledTime String           @map("scheduled_time")
  takenAt       DateTime         @map("taken_at")
  date          DateTime

  @@index([medicineId, date])
  @@map("medicine_doses")
}

model WeightRecord {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  weight    Float
  date      DateTime
  notes     String?
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([userId, date])
  @@index([userId, date])
  @@map("weight_records")
}

model PressureLog {
  id         Int      @id @default(autoincrement())
  userId     Int      @map("user_id")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  systolic   Int
  diastolic  Int
  pulse      Int?
  measuredAt DateTime @map("measured_at")
  status     String
  notes      String?
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([userId, measuredAt])
  @@map("pressure_logs")
}

model FoodEntry {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  meal      String
  food      String
  calories  Int
  protein   Float?
  carbs     Float?
  fats      Float?
  date      DateTime
  time      String
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId, date])
  @@index([meal])
  @@map("food_entries")
}

model SleepRecord {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  bedTime   String   @map("bed_time")
  wakeTime  String   @map("wake_time")
  hours     Float
  quality   String
  date      DateTime
  notes     String?
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([userId, date])
  @@index([userId, date])
  @@map("sleep_records")
}

model FCMToken {
  id         Int      @id @default(autoincrement())
  userId     Int      @map("user_id")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token      String   @unique
  deviceType String   @default("web") @map("device_type")
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("fcm_tokens")
}

model ContactMessage {
  id         Int       @id @default(autoincrement())
  name       String
  email      String
  phone      String?
  subject    String?
  message    String
  status     String    @default("new")
  isRead     Boolean   @default(false) @map("is_read")
  adminReply String?   @map("admin_reply")
  repliedAt  DateTime? @map("replied_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  @@index([status])
  @@index([isRead])
  @@index([createdAt])
  @@map("contact_messages")
}

model Rating {
  id         Int      @id @default(autoincrement())
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  userIp     String   @map("user_ip")
  rating     Int
  comment    String?
  isHelpful  Boolean? @map("is_helpful")

  // العلاقات
  medicalTool MedicalTool? @relation(fields: [entityId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([entityType, entityId, userIp])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("ratings")
}

model Favorite {
  id         Int      @id @default(autoincrement())
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  userIp     String   @map("user_ip")
  createdAt  DateTime @default(now()) @map("created_at")

  @@unique([entityType, entityId, userIp])
  @@index([entityType, entityId])
  @@index([userIp])
  @@map("favorites")
}

model ViewLog {
  id         Int      @id @default(autoincrement())
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  userIp     String   @map("user_ip")
  userAgent  String?  @map("user_agent")
  referer    String?
  sessionId  String?  @map("session_id")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([entityType, entityId])
  @@index([createdAt])
  @@index([sessionId])
  @@map("view_logs")
}

model Analytics {
  id              Int      @id @default(autoincrement())
  entityType      String   @map("entity_type")
  entityId        String   @map("entity_id")
  date            DateTime
  views           Int      @default(0)
  uniqueViews     Int      @default(0) @map("unique_views")
  timeSpent       Int      @default(0) @map("time_spent")
  bounceRate      Float    @default(0.00) @map("bounce_rate")
  likes           Int      @default(0)
  shares          Int      @default(0)
  comments        Int      @default(0)
  directTraffic   Int      @default(0) @map("direct_traffic")
  searchTraffic   Int      @default(0) @map("search_traffic")
  socialTraffic   Int      @default(0) @map("social_traffic")
  referralTraffic Int      @default(0) @map("referral_traffic")
  createdAt       DateTime @default(now()) @map("created_at")

  @@unique([entityType, entityId, date])
  @@index([date])
  @@map("analytics")
}

model HealthTip {
  id            Int              @id @default(autoincrement())
  titleAr       String           @map("title_ar")
  titleEn       String?          @map("title_en")
  contentAr     String           @map("content_ar")
  contentEn     String?          @map("content_en")
  categoryId    Int?             @map("category_id")
  category      ArticleCategory? @relation(fields: [categoryId], references: [id])
  frequency     String           @default("daily")
  scheduledDate DateTime?        @map("scheduled_date")
  isSeasonal    Boolean          @default(false) @map("is_seasonal")
  seasonMonths  String           @default("[]") @map("season_months")
  icon          String?
  image         String?
  viewCount     Int              @default(0) @map("view_count")
  likeCount     Int              @default(0) @map("like_count")
  shareCount    Int              @default(0) @map("share_count")
  isActive      Boolean          @default(true) @map("is_active")
  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @updatedAt @map("updated_at")

  @@index([categoryId])
  @@index([scheduledDate])
  @@index([isActive, scheduledDate])
  @@map("health_tips")
}

model VisualTip {
  id        Int      @id @default(autoincrement())
  titleAr   String   @map("title_ar")
  contentAr String?  @map("content_ar")
  imageUrl  String?  @map("image_url")
  isActive  Boolean  @default(true) @map("is_active")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([isActive, sortOrder])
  @@map("visual_tips")
}

model YoutubeVideo {
  id           Int       @id @default(autoincrement())
  channelId    String    @map("channel_id")
  videoId      String    @unique @map("video_id")
  title        String
  description  String?
  thumbnailUrl String?   @map("thumbnail_url")
  videoUrl     String    @map("video_url")
  channelTitle String?   @map("channel_title")
  publishedAt  DateTime? @map("published_at")
  durationSec  Int?      @map("duration_sec")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  @@index([channelId, publishedAt])
  @@map("youtube_videos")
}

model YoutubeSyncState {
  id            Int       @id @default(autoincrement())
  channelId     String    @unique @map("channel_id")
  lastAttemptAt DateTime? @map("last_attempt_at")
  lastSuccessAt DateTime? @map("last_success_at")
  lastError     String?   @map("last_error")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@map("youtube_sync_state")
}

model Guide {
  id          Int     @id @default(autoincrement())
  slug        String  @unique
  title       String
  subtitle    String?
  description String?
  icon        String? // Icon name from HeroIcons
  color       String? // Theme color name (rose, violet, etc.)
  keywords    String  @default("[]") // JSON array of keywords
  isActive    Boolean @default(true) @map("is_active")

  // Relations configurations (JSON)
  relatedSpecialties String @default("[]") @map("related_specialties") // Slugs of specialties

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("guides")
}
